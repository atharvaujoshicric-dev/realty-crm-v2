{
  "bwxsotr": {
    "description": "Song of the River - Primary Booking Sheet",
    "headers": {
      "0": "serial_no",
      "1": "booking_date",
      "2": "client_name",
      "3": "contact",
      "4": "plot_no",
      "5": "plot_size",
      "6": "basic_rate",
      "7": "infra",
      "8": "_skip_basic_amount",
      "9": "_skip_basic_infra",
      "10": "agreement_value",
      "11": "sdr",
      "12": "sdr_minus",
      "13": "maintenance",
      "14": "legal_charges",
      "15": "_skip_total_cost",
      "16": "_skip_received",
      "17": "_skip_remaining",
      "18": "loan_status",
      "19": "_skip_financing",
      "20": "_skip_loan_sanctioned",
      "21": "bank_name",
      "22": "_skip_ocr_received",
      "23": "_skip_ocr_amount",
      "24": "_skip_ocr_expected",
      "25": "_skip_ocr_date",
      "26": "_skip_file_submitted",
      "27": "_skip_file_date",
      "28": "sdr_received",
      "29": "sdr_received_date",
      "30": "sanction_received",
      "31": "sanction_date",
      "32": "sanction_letter",
      "33": "banker_contact",
      "34": "disbursement_status",
      "35": "disbursement_date",
      "36": "remark",
      "37": "doc_submitted"
    },
    "required_fields": [
      "client_name",
      "serial_no",
      "booking_date",
      "plot_no"
    ],
    "derived_fields": {
      "basic_amount": "basic_rate * plot_size / 1000",
      "basic_infra": "basic_amount + infra",
      "total_cost": "basic_infra + sdr + sdr_minus + maintenance + legal_charges"
    }
  },
  "cheque_details": {
    "description": "Payment/Cheque Records",
    "headers": {
      "0": "cust_name",
      "1": "plot_no",
      "2": "bank_detail",
      "3": "cheque_no",
      "4": "cheque_date",
      "5": "amount",
      "6": "entry_type"
    }
  },
  "previous_team_bookings": {
    "description": "Previous Team Records",
    "headers": {
      "0": "client_name",
      "1": "plot_no",
      "2": "plot_size",
      "3": "agreement_value"
    }
  }
}
